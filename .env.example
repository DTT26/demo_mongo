# ============================================================
# 🍽️ BookEat Backend — Environment Variables Example
# ============================================================
# Sao chép file này thành .env và điền giá trị thực
# cp .env.example .env
# ============================================================

# ────────────────────────────────────────────────────────────
# 🚀 SERVER
# ────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
APP_BASE_URL=http://localhost:3001

# ────────────────────────────────────────────────────────────
# 🍃 DATABASE — MongoDB
# ────────────────────────────────────────────────────────────
# Local MongoDB
MONGO_URI=mongodb://localhost:27017/bookeat

# MongoDB Atlas (Cloud) — bỏ comment nếu dùng Atlas
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/bookeat?retryWrites=true&w=majority

MONGO_DB_NAME=bookeat

# ────────────────────────────────────────────────────────────
# 🔐 JWT AUTHENTICATION
# ────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_REFRESH_EXPIRES_IN=30d

# ────────────────────────────────────────────────────────────
# 🌐 CORS
# ────────────────────────────────────────────────────────────
# Nhiều origin cách nhau bằng dấu phẩy
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ────────────────────────────────────────────────────────────
# 🔑 GOOGLE OAUTH 2.0
# ────────────────────────────────────────────────────────────
# Lấy tại: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# ────────────────────────────────────────────────────────────
# 💳 PAYOS (Thanh toán)
# ────────────────────────────────────────────────────────────
# Lấy tại: https://business.payos.vn
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
PAYOS_ENDPOINT=https://api-merchant.payos.vn
PAYOS_RETURN_URL=http://localhost:5173/payment/success
PAYOS_CANCEL_URL=http://localhost:5173/payment/cancel
PAYOS_WEBHOOK_URL=http://localhost:3001/api/v1/payments/webhook
PAYOS_EXPIRATION_MINUTES=43200

# ────────────────────────────────────────────────────────────
# 🖼️ CLOUDINARY (Upload ảnh)
# ────────────────────────────────────────────────────────────
# Lấy tại: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=bookeat/chat
CLOUDINARY_SECURE=true

# ────────────────────────────────────────────────────────────
# 🤖 OPENAI (AI Recommendations)
# ────────────────────────────────────────────────────────────
# Lấy tại: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=30000
AI_TOOL_TIMEOUT_MS=10000
AI_ENABLED=true
AI_MAX_INPUT_CHARS=2000
AI_MAX_HISTORY_MESSAGES=8
AI_MAX_OUTPUT_TOKENS=800
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX_REQUESTS=10
AI_DAILY_BUDGET_ESTIMATE=0
AI_MONTHLY_BUDGET_ESTIMATE=0
AI_PUBLIC_TOOLS_ENABLED=true
AI_CUSTOMER_DYNAMIC_TOOLS_ENABLED=true
AI_AVAILABILITY_TOOL_ENABLED=true
AI_VOUCHER_TOOL_ENABLED=true
AI_BOOKING_PREVIEW_TOOL_ENABLED=true
AI_BOOKING_CONFIRM_ENABLED=true
AI_KNOWLEDGE_SEARCH_ENABLED=true
AI_OWNER_TOOLS_ENABLED=true
AI_ADMIN_TOOLS_ENABLED=true
AI_KNOWLEDGE_AUTO_SEED=true
AI_PENDING_ACTION_TTL_MINUTES=10
AI_MAX_TOOL_ROUNDS=3
AI_MAX_TOOL_CALLS=5

# Phase 1 mock endpoint. Production defaults to disabled when this is omitted.
AI_MOCK_ENABLED=true

# ────────────────────────────────────────────────────────────
# 📧 EMAIL (Nodemailer — Gmail SMTP)
# ────────────────────────────────────────────────────────────
# ⚠️  MAIL_PASSWORD phải là Google App Password, KHÔNG phải mật khẩu Gmail thường!
# Bật 2FA rồi tạo App Password tại: https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_FROM=Book Eat <your_email@gmail.com>
MAIL_REPLY_TO=your_email@gmail.com
ADMIN_EMAIL=admin@bookeat.vn

# URL frontend (dùng để tạo link verify email / reset password)
FRONTEND_URL=http://localhost:5173

# ────────────────────────────────────────────────────────────
# ⚡ REDIS (Cache & Rate Limiting) — Tuỳ chọn
# ────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ────────────────────────────────────────────────────────────
# 🛡️ RATE LIMITING
# ────────────────────────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ────────────────────────────────────────────────────────────
# 📁 UPLOAD FILE
# ────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp
